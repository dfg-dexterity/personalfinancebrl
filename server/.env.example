# Pooled connection (PgBouncer) — used by the app at runtime.
DATABASE_URL="postgresql://user:password@host:6543/postgres?pgbouncer=true&connection_limit=1"
# Direct connection — used by `prisma db push` / migrations.
DIRECT_URL="postgresql://user:password@host:5432/postgres"
JWT_SECRET="change-me-to-a-long-random-string"
PORT=3001
# Open Finance provider: "mock" (default) or a real aggregator like "pluggy"
OPENFINANCE_PROVIDER="mock"
# In production, set this to your deployed site URL, e.g. https://your-app.vercel.app
CLIENT_ORIGIN="http://localhost:5173"

# --- Real Open Finance aggregator (optional) ---
# To connect to real Open Finance Brasil data, sign up with an authorized
# aggregator (e.g. Pluggy: https://pluggy.ai) and fill these in, then set
# OPENFINANCE_PROVIDER="pluggy".
# PLUGGY_CLIENT_ID=""
# PLUGGY_CLIENT_SECRET=""
