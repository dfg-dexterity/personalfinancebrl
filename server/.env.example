DATABASE_URL="file:./dev.db"
JWT_SECRET="change-me-to-a-long-random-string"
PORT=3001
# Open Finance provider: "mock" (default) or a real aggregator like "pluggy"
OPENFINANCE_PROVIDER="mock"
CLIENT_ORIGIN="http://localhost:5173"

# --- Real Open Finance aggregator (optional) ---
# To connect to real Open Finance Brasil data, sign up with an authorized
# aggregator (e.g. Pluggy: https://pluggy.ai) and fill these in, then set
# OPENFINANCE_PROVIDER="pluggy".
# PLUGGY_CLIENT_ID=""
# PLUGGY_CLIENT_SECRET=""
